# ─────────────────────────────────────────────
#  CodeRunner — Environment Variables
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# JWT — use a long random string in production
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# PostgreSQL (RDS or local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=coderunner
DB_USER=postgres
DB_PASSWORD=devpassword
DB_SSL=false          # Set to true on AWS RDS

# Docker execution limits
DOCKER_MEMORY_LIMIT=128m
DOCKER_CPU_LIMIT=0.5
DOCKER_TIMEOUT_SECONDS=10
DOCKER_PIDS_LIMIT=32

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20
EXECUTE_RATE_LIMIT_MAX=10

# CORS — set to your frontend domain in production
CORS_ORIGIN=http://localhost:5500
